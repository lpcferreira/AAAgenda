# ─── Google OAuth ───────────────────────────────────────────────────
# Crie em: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=COLE_AQUI
GOOGLE_CLIENT_SECRET=COLE_AQUI

# ─── NextAuth ───────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=COLE_AQUI
NEXTAUTH_URL=http://localhost:3000

# ─── Anthropic (Claude) ─────────────────────────────────────────────
# Crie em: https://console.anthropic.com
ANTHROPIC_API_KEY=COLE_AQUI

# ─── App ────────────────────────────────────────────────────────────
# Fuso padrão (pode ser sobrescrito por usuário)
DEFAULT_TIMEZONE=America/Sao_Paulo
